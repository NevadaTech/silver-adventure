# ===========================================
# Supabase — Cloud
# ===========================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api-keys
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
# Browser access for auth session management (safe: publishable key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
# Brain-only — full-access service role key (NEVER ship to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# App
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Brain — Gemini (Google Generative AI)
# ===========================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ===========================================
# Brain — Agent (clustering scheduler)
# ===========================================
# Cron schedule for the clustering agent (default: every 60s)
AGENT_CRON_SCHEDULE=*/60 * * * * *
# Toggle the agent loop on/off without redeploying
AGENT_ENABLED=true
# Toggle Gemini-based inference for ambiguous matches
AI_MATCH_INFERENCE_ENABLED=true

# ===========================================
# Debug / Logging
# ===========================================
# Server-side logger — set "true" to enable console output in Route Handlers,
# Server Components, and use cases. Any other value = disabled (NullLogger).
DEBUG_ENABLED=true

# Client-side logger — set "true" to enable console output in Client Components
# and hooks. This is the ONLY NEXT_PUBLIC_ var besides APP_URL — it's a boolean
# flag, NOT a secret. Does NOT violate BFF pattern.
NEXT_PUBLIC_DEBUG_ENABLED=true
